{
  "name": "peterblog",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:main": "turbo run dev --filter=@peterblog/main",
    "dev:reading": "turbo run dev --filter=@peterblog/reading",
    "build": "turbo run build",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.4.0"
  }
}
